NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Token de leitura da API TMDB (https://www.themoviedb.org/settings/api)
# Necessário para busca e preenchimento automático de filmes no admin
TMDB_API_READ_TOKEN=

# Chave interna compartilhada entre Next.js e Django para comunicação servidor-a-servidor.
# Deve ser o mesmo valor configurado em INTERNAL_API_KEY no backend.
INTERNAL_API_KEY=

# URL do backend acessível pelo servidor Next.js (pode diferir em Docker).
# Se não definido, usa NEXT_PUBLIC_API_BASE_URL.
# BACKEND_INTERNAL_URL=http://backend:8000
