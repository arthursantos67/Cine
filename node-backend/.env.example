PORT=3000
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/cineprime
JWT_SECRET=<secret-forte-min-32-chars>
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=<refresh-secret-forte-min-32-chars>
JWT_REFRESH_EXPIRES_IN=7d
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
# Chave interna compartilhada com o Next.js para comunicação servidor-a-servidor
INTERNAL_API_KEY=<chave-aleatoria-32-bytes-hex>
